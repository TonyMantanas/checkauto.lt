# Replace re_xxxxxxxxx with your real Resend API key before serving or deploying.
RESEND_API_KEY=re_xxxxxxxxx
CONTACT_FROM_EMAIL=mail@noreply.checkauto.lt
CONTACT_TO_EMAIL=info@checkauto.lt

# Optional but recommended for stable hashed rate-limit keys.
# Supabase provides SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY automatically in production.
RATE_LIMIT_HASH_SECRET=replace_with_a_long_random_secret
